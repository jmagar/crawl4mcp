# The transport for the MCP server - either 'sse' or 'stdio' (defaults to sse if left empty)
TRANSPORT=

# Host to bind to if using sse as the transport (leave empty if using stdio)
HOST=

# Port to listen on if using sse as the transport (leave empty if using stdio)
PORT=

# URL for your self-hosted BGE-large embedding server
EMBEDDING_SERVER_URL=http://10.1.0.7/embed

# Qdrant vector database configuration
# URL for Qdrant server (e.g. http://localhost:6333 for local, or your cloud Qdrant URL)
QDRANT_URL=
# Optional API key for Qdrant Cloud
QDRANT_API_KEY=
# Qdrant collection name (defaults to crawled_pages if left empty)
QDRANT_COLLECTION=
# Vector dimension for embeddings (BGE-large is 1024)
VECTOR_DIM=1024

# --- Optional: For contextual summaries using an OpenAI model ---
# If you want to use contextual embeddings (summaries), provide an OpenAI API key and model.
# If OPENAI_API_KEY is not set, contextual summaries will be disabled.
OPENAI_API_KEY=
# The LLM you want to use for contextual embeddings (e.g., gpt-3.5-turbo, gpt-4o-mini)
# Leave this blank or remove OPENAI_API_KEY to disable contextual summaries.
SUMMARIZATION_MODEL_CHOICE=