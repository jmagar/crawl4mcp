# Environment variables for Crawl4AI RAG MCP Server

# -- Core Server Configuration --
HOST="0.0.0.0"                 # Host for the MCP server to listen on
PORT="8051"                    # Port for the MCP server
# PATH="/mcp"                  # Optional: Base path for MCP server endpoints if behind a reverse proxy, e.g. /mcp

# -- Qdrant Configuration --
QDRANT_URL="http://localhost:6333"      # URL of your Qdrant instance (use "http://qdrant:6333" if running Qdrant service via docker-compose from this project)
# QDRANT_API_KEY="your_qdrant_api_key"  # Uncomment and set if your Qdrant instance uses an API key
QDRANT_COLLECTION="crawl4ai_mcp"        # Name of the Qdrant collection to use/create

# -- Embedding Model Configuration --
EMBEDDING_SERVER_URL="http://localhost:8080/embed" # URL of your TEI embedding server (e.g., BAAI/bge-large-en-v1.5)
EMBEDDING_SERVER_BATCH_SIZE="64"     # Batch size for sending texts to the embedding server
VECTOR_DIM="1024"                       # Dimension of the vectors produced by your embedding model (1024 for BAAI/bge-large-en-v1.5)

# -- Text Processing & Crawling Configuration --
CHUNK_SIZE="500"                        # Default chunk size for text processing before embedding
CHUNK_OVERLAP="100"                     # Default chunk overlap for text processing
MARKDOWN_CHUNK_SIZE="750"               # Chunk size for processing markdown content from web pages
CRAWLER_VERBOSE="false"                 # Enable verbose logging for the crawler. Set to "true" for detailed crawler output.

# -- MCP Server Behavior --
# CRAWL4AI_MCP_NAME="crawl4ai_mcp"      # Optional: Basename for the log file (e.g., crawl4ai_mcp.log)
LOG_LEVEL="INFO"                        # Logging level for the MCP server (e.g., DEBUG, INFO, WARNING, ERROR)

# -- Optional: OpenAI for Summarization (Currently not a primary feature, but framework supports it) --
# OPENAI_API_KEY="your_openai_api_key"
# SUMMARIZATION_MODEL_CHOICE="gpt-3.5-turbo"

# -- Optional: Visualization and Analytics Settings --
# CLUSTERING_DEFAULT_NUM_CLUSTERS="5"   # Default number of clusters for K-means clustering
# CLUSTERING_MAX_SAMPLE_SIZE="10000"    # Maximum number of vectors to sample for clustering
# NLTK_DATA="/path/to/nltk_data"        # Custom path for NLTK data (default is the nltk standard path)

# -- Optional: Hugging Face Hub Token (if your TEI model requires it for download from a private repo) --
# HUGGING_FACE_HUB_TOKEN="your_hf_token_here"